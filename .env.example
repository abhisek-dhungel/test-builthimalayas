# Copy to .env.local for local development:
#   cp .env.example .env.local

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Session signing (use a long random string in production)
SESSION_SECRET=use-a-long-random-string-here

# Database driver:
#   sqlite  = local development (data/rent.db) — default
#   mysql   = cPanel production
DATABASE_DRIVER=sqlite

# MySQL — required when DATABASE_DRIVER=mysql (cPanel → MySQL Databases)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_cpanel_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=your_cpanel_db_name
