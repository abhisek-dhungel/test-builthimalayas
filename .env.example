# Copy to .env.local for local development:
#   cp .env.example .env.local

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Session signing (use a long random string in production)
SESSION_SECRET=use-a-long-random-string-here

# Database driver:
#   sqlite  = local development (data/rent.db) — default
#   mysql   = production (Vercel / cPanel)
DATABASE_DRIVER=sqlite

# MySQL — required when DATABASE_DRIVER=mysql
# Create an empty database + user only. Tables are created automatically.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_cpanel_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=your_cpanel_db_name
# Set true for most cloud MySQL hosts (Railway, Aiven, etc.)
MYSQL_SSL=true

# Cloudinary — required on Vercel for photo/video storage
# Dashboard → Settings → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Dashboard → Settings → Upload → Upload presets → Add unsigned preset
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
